      "paragraphs": [
        {
          "has_heading": false,
          "heading": "",
          "text": "Invisalign<sup>®</sup> aligners are clear, removable trays that move teeth through a series of custom-fitted aligners. They’re popular for adults and teens who want an unobtrusive, flexible option."
        },
        {
          "has_heading": false,
          "heading": "",
          "text": "We use digital scanning and 3D treatment planning to visualize results and tailor the series of aligners to your needs."
